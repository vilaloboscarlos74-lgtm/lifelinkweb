# === BASE DE DATOS ===
# Local:
# DATABASE_URL=postgresql://postgres:password@localhost:5432/lifelink_db
# Neon (producción) — copia la cadena de conexión desde el dashboard de Neon:
DATABASE_URL=postgresql://user:pass@ep-xxx.region.aws.neon.tech/neondb?sslmode=require

# === JWT ===
# Genera una clave segura con: openssl rand -hex 32
SECRET_KEY=CAMBIA_ESTA_CLAVE_POR_UNA_SEGURA
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# === APP ===
APP_NAME=LifeLink Medical
APP_VERSION=1.0.0
DEBUG=false
# URLs del frontend separadas por coma (local + Vercel):
ALLOWED_ORIGINS=http://localhost:5173,https://tu-app.vercel.app

# === UPLOADS ===
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=5242880

# === TWILIO SMS (2FA por SMS) ===
# Obtén estas credenciales en https://console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_FROM_NUMBER=+1234567890
